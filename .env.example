# --- Supabase (required for accounts + cross-device sync) ---
# Create a free project at https://supabase.com, then go to
# Project Settings -> API to find these two values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Anthropic (optional, only needed for AI Assist) ---
# Get a key at https://console.anthropic.com and add it in Vercel under
# Project Settings -> Environment Variables. Never commit your real key.
# NOTE: this one has no VITE_ prefix -- it's used server-side only, in api/generate.js.
ANTHROPIC_API_KEY=sk-ant-...
